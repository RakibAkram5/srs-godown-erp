# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/srs_godown?schema=public"

# ── Auth (JWT) ────────────────────────────────────────────
# Access token: short-lived. Refresh token: long-lived (revocable).
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── Default seeded admin ──────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@srsgodown.com
SEED_ADMIN_NAME=Administrator
