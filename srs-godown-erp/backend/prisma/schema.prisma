// SRS Godown ERP — Prisma schema
// PHASE 2: Authentication & User Management.
// Tables: users (extended), settings, refresh_tokens, login_history, audit_logs.
// No business tables yet — those belong to future phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum AuditAction {
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PROFILE_UPDATE
}

model User {
  id           String    @id @default(uuid())
  name         String
  username     String    @unique
  email        String    @unique
  phone        String?
  password     String
  role         Role      @default(ADMIN)
  profileImage String?   @map("profile_image")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]
  auditLogs     AuditLog[]

  @@map("users")
}

// Hashed refresh tokens — enables revocation on logout / password change.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// One row per login session — tracks device/browser/IP + logout time.
model LoginHistory {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?   @map("ip_address")
  browser   String?
  device    String?
  os        String?
  status    String    @default("SUCCESS")
  loginAt   DateTime  @default(now()) @map("login_at")
  logoutAt  DateTime? @map("logout_at")

  @@index([userId])
  @@map("login_history")
}

// Immutable record of security-relevant actions.
model AuditLog {
  id        String      @id @default(uuid())
  userId    String?     @map("user_id")
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    AuditAction
  detail    String?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────
// PHASE 3 — Masters (Categories, Brands, Units)
// Independent lookup tables. Products (a later phase) will
// reference these. Each supports an Active/Inactive status.
// ─────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  shortName String?  @map("short_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("units")
}

// Single-row company/application settings.
model Settings {
  id          String   @id @default(uuid())
  companyName String   @default("SRS Godown ERP") @map("company_name")
  companyLogo String?  @map("company_logo")
  phone       String?
  address     String?
  currency    String   @default("PKR")
  language    String   @default("en")
  theme       String   @default("system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
