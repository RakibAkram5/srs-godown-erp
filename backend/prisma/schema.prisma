// SRS Godown ERP — Prisma schema
// PHASE 2: Authentication & User Management.
// Tables: users (extended), settings, refresh_tokens, login_history, audit_logs.
// No business tables yet — those belong to future phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  EMPLOYEE
}

enum AuditAction {
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PROFILE_UPDATE
}

model User {
  id           String    @id @default(uuid())
  name         String
  username     String    @unique
  email        String    @unique
  phone        String?
  password     String
  role         Role      @default(ADMIN)
  permissions  String[]  @default([])
  profileImage String?   @map("profile_image")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]
  auditLogs     AuditLog[]

  @@map("users")
}

// Hashed refresh tokens — enables revocation on logout / password change.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// One row per login session — tracks device/browser/IP + logout time.
model LoginHistory {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?   @map("ip_address")
  browser   String?
  device    String?
  os        String?
  status    String    @default("SUCCESS")
  loginAt   DateTime  @default(now()) @map("login_at")
  logoutAt  DateTime? @map("logout_at")

  @@index([userId])
  @@map("login_history")
}

// Immutable record of security-relevant actions.
model AuditLog {
  id        String      @id @default(uuid())
  userId    String?     @map("user_id")
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    AuditAction
  detail    String?
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────
// PHASE 3 — Masters (Categories, Brands, Units)
// Independent lookup tables. Products (a later phase) will
// reference these. Each supports an Active/Inactive status.
// ─────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  shortName String?  @map("short_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("units")
}

// ─────────────────────────────────────────────────────────
// PHASE 4 — Product Management
// References masters by id (kept as plain columns so Phase 3
// models stay untouched). Soft-delete via isDeleted.
// ─────────────────────────────────────────────────────────

model Product {
  id     String @id @default(uuid())
  codeNo Int    @unique @default(autoincrement()) @map("code_no")

  name        String
  productCode String? @unique @map("product_code")
  sku         String? @unique
  barcode     String?
  image       String?
  description String?

  // Master references (ids only — no FK relation to Phase 3 models)
  categoryId String? @map("category_id")
  brandId    String? @map("brand_id")
  unitId     String? @map("unit_id")

  // Location
  warehouse String?
  rack      String?
  shelf     String?

  // Bike compatibility (multi-select), e.g. ["Honda","Deluxe"]
  bikes String[]

  // Pricing
  purchasePrice Float @default(0) @map("purchase_price")
  salePrice     Float @default(0) @map("sale_price")

  // Stock
  openingStock Int @default(0) @map("opening_stock")
  minimumStock Int @default(0) @map("minimum_stock")
  currentStock Int @default(0) @map("current_stock")

  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([brandId])
  @@index([isDeleted])
  @@map("products")
}

// ─────────────────────────────────────────────────────────
// PHASE 5 — Purchase & Stock Inward (+ Vendors)
// Products are referenced by id (plain columns) so Phase 4
// stays untouched. Vendor/Purchase/Return relate to each other.
// ─────────────────────────────────────────────────────────

enum TaxType {
  NONE
  PERCENT
  FIXED
}

enum PurchaseStatus {
  DRAFT
  COMPLETED
}

enum StockMovementType {
  PURCHASE_IN
  PURCHASE_RETURN_OUT
  SALE_OUT
  SALE_RETURN_IN
  ADJUSTMENT
}

model Vendor {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  openingBalance Float    @default(0) @map("opening_balance")
  balance        Float    @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  purchases Purchase[]
  returns   PurchaseReturn[]
  payments  Payment[]

  @@map("vendors")
}

model Purchase {
  id         String         @id @default(uuid())
  codeNo     Int            @unique @default(autoincrement()) @map("code_no")
  purchaseNo String?        @unique @map("purchase_no")
  purchaseDate DateTime     @default(now()) @map("purchase_date")

  vendorId String @map("vendor_id")
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  warehouse String?
  rack      String?
  shelf     String?

  subTotal        Float          @default(0) @map("sub_total")
  discount        Float          @default(0)
  taxType         TaxType        @default(NONE) @map("tax_type")
  taxValue        Float          @default(0) @map("tax_value")
  taxAmount       Float          @default(0) @map("tax_amount")
  totalAmount     Float          @default(0) @map("total_amount")
  paidAmount      Float          @default(0) @map("paid_amount")
  previousBalance Float          @default(0) @map("previous_balance")
  notes           String?
  status          PurchaseStatus @default(DRAFT)

  items   PurchaseItem[]
  returns PurchaseReturn[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vendorId])
  @@index([status])
  @@map("purchases")
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId     String  @map("product_id")
  productName   String  @map("product_name")
  quantity      Int
  purchasePrice Float   @map("purchase_price")
  discount      Float   @default(0)
  lineTotal     Float   @map("line_total")

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model PurchaseReturn {
  id         String   @id @default(uuid())
  codeNo     Int      @unique @default(autoincrement()) @map("code_no")
  returnNo   String?  @unique @map("return_no")
  returnDate DateTime @default(now()) @map("return_date")

  purchaseId String   @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  vendorId   String   @map("vendor_id")
  vendor     Vendor   @relation(fields: [vendorId], references: [id])

  totalAmount Float  @default(0) @map("total_amount")
  notes       String?

  items PurchaseReturnItem[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([purchaseId])
  @@index([vendorId])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id       String @id @default(uuid())
  returnId String @map("return_id")
  return   PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId   String @map("product_id")
  productName String @map("product_name")
  quantity    Int
  price       Float
  lineTotal   Float  @map("line_total")

  @@index([returnId])
  @@map("purchase_return_items")
}

model StockMovement {
  id          String            @id @default(uuid())
  productId   String            @map("product_id")
  productName String            @map("product_name")
  type        StockMovementType
  quantity    Int // signed: + inward, - outward
  balanceAfter Int              @map("balance_after")
  referenceType String?         @map("reference_type")
  referenceId   String?         @map("reference_id")
  referenceNo   String?         @map("reference_no")
  note          String?
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────
// PHASE 6 — Sales & Stock Outward
// Mirror of Purchase. Products referenced by id (plain columns).
// Walk-in customer stored inline (name/phone) — no Customer table yet.
// ─────────────────────────────────────────────────────────

enum SaleStatus {
  DRAFT
  COMPLETED
}

model Sale {
  id       String     @id @default(uuid())
  codeNo   Int        @unique @default(autoincrement()) @map("code_no")
  saleNo   String?    @unique @map("sale_no")
  saleDate DateTime   @default(now()) @map("sale_date")

  customerName  String? @map("customer_name")
  customerPhone String? @map("customer_phone")

  dealerId String? @map("dealer_id")
  dealer   Dealer? @relation(fields: [dealerId], references: [id])

  subTotal    Float      @default(0) @map("sub_total")
  discount    Float      @default(0)
  taxType     TaxType    @default(NONE) @map("tax_type")
  taxValue    Float      @default(0) @map("tax_value")
  taxAmount       Float      @default(0) @map("tax_amount")
  totalAmount     Float      @default(0) @map("total_amount")
  paidAmount      Float      @default(0) @map("paid_amount")
  previousBalance Float      @default(0) @map("previous_balance")
  notes           String?
  status          SaleStatus @default(DRAFT)

  items      SaleItem[]
  returns    SaleReturn[]
  dispatches Dispatch[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([dealerId])
  @@map("sales")
}

model SaleItem {
  id     String @id @default(uuid())
  saleId String @map("sale_id")
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId       String @map("product_id")
  productName     String @map("product_name")
  quantity        Int
  pendingQuantity Int    @default(0) @map("pending_quantity")
  salePrice       Float  @map("sale_price")
  discount        Float  @default(0)
  lineTotal       Float  @map("line_total")

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model SaleReturn {
  id         String   @id @default(uuid())
  codeNo     Int      @unique @default(autoincrement()) @map("code_no")
  returnNo   String?  @unique @map("return_no")
  returnDate DateTime @default(now()) @map("return_date")

  saleId String @map("sale_id")
  sale   Sale   @relation(fields: [saleId], references: [id])

  totalAmount Float   @default(0) @map("total_amount")
  notes       String?

  items SaleReturnItem[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([saleId])
  @@map("sale_returns")
}

model SaleReturnItem {
  id       String     @id @default(uuid())
  returnId String     @map("return_id")
  return   SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId   String @map("product_id")
  productName String @map("product_name")
  quantity    Int
  price       Float
  lineTotal   Float  @map("line_total")

  @@index([returnId])
  @@map("sale_return_items")
}

// ─────────────────────────────────────────────────────────
// PHASE 7 — Dealers (customers we sell to, with ledger balance)
// ─────────────────────────────────────────────────────────

model Dealer {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  email          String?
  address        String?
  city           String?
  openingBalance Float    @default(0) @map("opening_balance")
  balance        Float    @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  sales    Sale[]
  payments Payment[]

  @@map("dealers")
}

// ─────────────────────────────────────────────────────────
// PHASE 8 — Ledgers (payments to vendors, receipts from dealers)
// ─────────────────────────────────────────────────────────

enum PaymentType {
  VENDOR_PAYMENT
  DEALER_RECEIPT
}

enum PaymentMethod {
  CASH
  BANK
  CARD
  CHEQUE
  OTHER
}

model Payment {
  id          String        @id @default(uuid())
  codeNo      Int           @unique @default(autoincrement()) @map("code_no")
  voucherNo   String?       @unique @map("voucher_no")
  type        PaymentType
  amount      Float
  method      PaymentMethod @default(CASH)
  paymentDate DateTime      @default(now()) @map("payment_date")
  notes       String?

  vendorId String? @map("vendor_id")
  vendor   Vendor? @relation(fields: [vendorId], references: [id])
  dealerId String? @map("dealer_id")
  dealer   Dealer? @relation(fields: [dealerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vendorId])
  @@index([dealerId])
  @@index([type])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────
// PHASE 9 — Dispatch (linked to a sale invoice)
// ─────────────────────────────────────────────────────────

model Dispatch {
  id         String   @id @default(uuid())
  codeNo     Int      @unique @default(autoincrement()) @map("code_no")
  dispatchNo String?  @unique @map("dispatch_no")

  saleId String @map("sale_id")
  sale   Sale   @relation(fields: [saleId], references: [id])

  biltyNumber     String   @map("bilty_number")
  transporterName String   @map("transporter_name")
  city            String
  dispatchDate    DateTime @default(now()) @map("dispatch_date")
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([saleId])
  @@map("dispatches")
}

// Single-row company/application settings.
model Settings {
  id          String   @id @default(uuid())
  companyName String   @default("SRS Godown ERP") @map("company_name")
  companyLogo String?  @map("company_logo")
  phone       String?
  address     String?
  currency    String   @default("PKR")
  language    String   @default("en")
  theme       String   @default("system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
